@inherits Custom.Hybrid.RazorTyped
@using AppCode.Data
@{
  var rs = As<AppResources>(App.Resources);

  var query = App.GetQuery("Resource");
  var eduResourceStream = query.GetStream("Default");

  var eduResource = As<OpenEduResource>(eduResourceStream);
  var categories = eduResource.Categories.ToList();
  var translations = eduResource.Translations.ToList();
  var copyrights = eduResource.Copyright.ToList();
  var assets = eduResource.Assets.ToList();
  var contributors = eduResource.Contributors.ToList();
}

<div class="app-oer d-flex flex-column g-1 w-100" @Kit.Toolbar.Empty().Edit(eduResource)>
  @* Link back to all resources *@
  <a class="d-flex flex-row g-4 align-items-center mb-4" href='@Link.To(parameters: MyPage.Parameters.Remove("doc"))'>
    <div class="me-2">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" style="height:14px">
        <path xmlns="http://www.w3.org/2000/svg"
          d="M9.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l192 192c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L77.3 256 246.6 86.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-192 192z" />
      </svg>
    </div>
    <div class="mt-1">@rs.String("AllResources")</div>
  </a>

  @* Picture, Title, Teaser *@
  <div class="d-flex flex-row mb-2">
    <div class="me-4">
      @eduResource.Picture("Preview", settings: "Square", width: 100, imgClass: "rounded-circle mb-2")
    </div>
    <div>
      <h1 class="font-weight-medium">@eduResource.Title</h1>
      <section class="w-100 mb-4">
        @eduResource.Html(nameof(eduResource.Teaser))
      </section>
    </div>
  </div>

  @* Description *@
  <section class="w-100 mb-4">
    @eduResource.Html(nameof(eduResource.Description))
  </section>


  @* Assets / Resources *@
  <section class="w-100 mb-4" @Kit.Toolbar.Empty().Edit(eduResource.Assets)>
    <h3 class="font-weight-medium">@rs.Assets</h3>
    @if (assets.Count == 0)
    {
      <div>None</div>
    }
    else
    {
      <ul class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3 docs-tiles list-unstyled">
        @foreach (var asset in assets)
        {
          <li class="col" @Kit.Toolbar.Empty().Edit(asset)>
            <div class="card h-100 text-center position-relative">
              <div class="card-body d-flex flex-column justify-content-center align-items-center py-4">
                <icon class="mb-2">
                  @Html.Raw(asset.LinkType.Icon.Replace("#000000", "currentColor"))
                </icon>
                <div class="fw-semibold">@asset.Title</div>
                <div class="small text-muted mt-1">@Html.Raw(asset.Description)</div>
              </div>
              <a href="@asset.Link" target="_blank" rel="noopener noreferrer nofollow" class="stretched-link"></a>
            </div>
          </li>
        }
      </ul>
    }
  </section>

  @* Contributors *@
  <section class="w-100 mb-4">
    <h3 class="font-weight-medium mb-3">@rs.Contributors</h3>
    <div class="row w-100 mb-2 styled-table-header p-2 rounded-lg">
      <div class="col font-weight-medium">
        @rs.Name
      </div>
      <div class="col">
        @rs.ContactInfo
      </div>
    </div>
    @foreach (var contributor in contributors)
    {
      var contributorLink = Link.To(parameters: MyPage.Parameters
        .Flush()
        .Set("contributors", contributor.Id)
      );

      <a class="row w-100 border-bottom pb-4 pt-2 ps-2 pe-2" href="@contributorLink"
      @Kit.Toolbar.Empty().Edit(contributor)>
        <div class="col font-weight-medium">
          @Html.Raw(contributor.NameVisible)
        </div>
        <div class="col">
          @Html.Raw(contributor.ContactInfo)
        </div>
      </a>
    }
  </section>

  @* Categories *@
  <section class="w-100 mb-4" @Kit.Toolbar.Empty().Edit(eduResource.Categories))>
    <h3 class="font-weight-medium">@rs.Categories</h3>
    @String.Join(", ", categories.Select(c => c.Title))

    @if (categories.Count == 0)
    {
      <span>None</span>
    }
  </section>

  @* Translations / Languages *@
  <section class="w-100 mb-4">
    <h3 class="font-weight-medium">@rs.Translations</h3>
    @if (translations.Count == 0)
    {
      <span>None</span>
    }
    else foreach (var translation in translations)
    {
      <div>
        <div class="font-weight-medium">
          @translation.Title
          (@translation.Code)
        </div>
      </div>
    }
  </section>

  @* Copyright *@
  <section class="w-100 mb-4">
    <h3 class="font-weight-medium">@rs.Copyright</h3>
    @if (copyrights.Count == 0)
    {
      <span>Unknown</span>
    }
    else foreach (var copyright in copyrights)
    {
      <div>
        <div class="font-weight-medium">
          @copyright.Title
          (@copyright.Code)
        </div>
      </div>
    }
    
  </section>
</div>

@Html.Partial("./shared/Assets.cshtml")

<style>
  .docs-tiles .card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .docs-tiles .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .docs-tiles .card svg {
    transition: transform 0.2s ease;
    width: 48px;
    height: 48px;
    color: #452A78 !important;
    
  }
  
</style>